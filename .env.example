# Copy this file to .env and edit before running `docker compose up -d --build`.
# .env is gitignored — never commit real values.

# ── Public URLs ───────────────────────────────────────────────────────────────
# The address browsers use to reach each service. For a bare server use http://<SERVER_IP>:<port>;
# with a domain + reverse proxy use https://your-domain and https://api.your-domain (see DEPLOY.md).
NEXT_PUBLIC_API_URL=http://localhost:5228
PHONIX_FRONTEND_URL=http://localhost:3000

# ── Published host ports ────────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=5228

# ── TLS / reverse proxy ──────────────────────────────────────────────────────────
# Leave both false for plain HTTP. When a proxy (nginx/Caddy) terminates TLS in front,
# set both to true so the real client IP and HTTPS scheme (Secure cookies) are honored.
PHONIX_BEHIND_PROXY=false
PHONIX_FORCE_HTTPS=false

# ── First admin account (owner) ──────────────────────────────────────────────────
# Without these, a brand-new deploy has NO admin account and no way to create one —
# registration only ever creates Customer accounts. scripts/install.sh prompts for
# both interactively on the terminal (never auto-generated); set them here yourself
# only if you're deploying without that script. Applied on every boot: creates the
# owner if missing, or fixes its role/password if it already exists (so you can also
# use this to recover a lost admin password — edit here, then `docker compose up -d`).
# The owner then creates every other staff/admin account from the admin panel itself.
PHONIX_OWNER_USERNAME=
PHONIX_OWNER_PASSWORD=

# ── Backup encryption (optional but strongly recommended) ───────────────────────
# Encrypts store backups downloaded or sent via Telegram from /admin/backup (AES-256-
# GCM). Leave unset and backups are plain JSON/zip. Set this ONCE before your first
# real backup and keep it somewhere safe OUTSIDE the server — losing it makes every
# encrypted backup taken with it permanently unrecoverable.
PHONIX_BACKUP_KEY=

# ── Cluster / High Availability (optional) ───────────────────────────────────────
# Business continuity only (a second server that takes over if this one becomes
# unreachable) — NOT load balancing. Leave PHONIX_CLUSTER_MODE unset/standalone for
# a normal single-server install; every var below is then ignored. scripts/install.sh
# prompts for all of these interactively when you choose Primary or Standby.
# standalone (default) | primary | standby
PHONIX_CLUSTER_MODE=standalone
# Short label so the admin panel's Cluster Management page can tell the two servers
# apart (e.g. germany, iran). Cosmetic only.
PHONIX_NODE_ID=
# The OTHER cluster node's reachable base URL. MUST be https:// — cluster sync carries
# orders, user data and the initial snapshot, so the link has to be encrypted. The
# server refuses to start with a plain http:// peer (see PHONIX_CLUSTER_ALLOW_INSECURE).
PHONIX_CLUSTER_PEER=
# Shared secret authenticating every request between the two nodes (HMAC) — never
# used for anything else. Generate once on the Primary (scripts/install.sh does this
# for you) and paste the SAME value into the Standby's .env.
PHONIX_CLUSTER_SECRET=
# Set to "true" ONLY for local/dev testing to allow a plain-HTTP peer. Leave empty in
# production — an unset value keeps the mandatory-HTTPS guard on.
PHONIX_CLUSTER_ALLOW_INSECURE=
# How often a Standby reconciles uploaded media (KYC docs, avatars, product/site images)
# with the Primary, in seconds. Optional; defaults to 60.
PHONIX_CLUSTER_MEDIA_SYNC_INTERVAL_SECONDS=
