#!/usr/bin/env bash
set -euo pipefail

REPO_URL="https://github.com/AbolfazlTafakori/Phonix.git"
APP_USER="phoenix"
BASE_DIR="/opt/phoenix"
REPO_DIR="$BASE_DIR/repo"
RELEASES_DIR="$BASE_DIR/releases"
CURRENT_LINK="$BASE_DIR/current"
CONF_DIR="/etc/phoenix"
ENV_FILE="$CONF_DIR/phoenix.env"
OWNER_FILE="$CONF_DIR/owner.env"
NGINX_SITE="/etc/nginx/sites-available/phoenix.conf"
DOTNET_PROJECT="backend/src/Phonix.Api"
DATA_DIR="/var/lib/phoenix"
BACKUP_DIR="$DATA_DIR/backups"
API_PORT=5228
WEB_PORT=3000
KEEP_RELEASES=3
KEEP_DATA_SNAPSHOTS=10

C_RESET="\033[0m"; C_BOLD="\033[1m"; C_BLUE="\033[1;34m"; C_GREEN="\033[1;32m"
C_YELLOW="\033[1;33m"; C_RED="\033[1;31m"; C_CYAN="\033[1;36m"

say()  { printf "%b\n" "${C_BLUE}::${C_RESET} $*"; }
ok()   { printf "%b\n" "${C_GREEN}вң”${C_RESET} $*"; }
warn() { printf "%b\n" "${C_YELLOW}!${C_RESET} $*"; }
die()  { printf "%b\n" "${C_RED}вң–${C_RESET} $*" >&2; exit 1; }
heading() { printf "\n%b\n" "${C_BOLD}${C_CYAN}== $* ==${C_RESET}"; }

require_root() {
    [[ $EUID -eq 0 ]] || die "Ш§ЫҢЩҶ Ш§ШЁШІШ§Шұ ШЁШ§ЫҢШҜ ШЁШ§ ШҜШіШӘШұШіЫҢ root Ш§Ш¬ШұШ§ ШҙЩҲШҜ (sudo p-ui)."
}

get_env() { grep -E "^$1=" "$ENV_FILE" 2>/dev/null | head -n1 | cut -d= -f2- || true; }

set_env() {
    local k="$1" v="$2"
    if grep -qE "^$k=" "$ENV_FILE"; then
        sed -i "s|^$k=.*|$k=$v|" "$ENV_FILE"
    else
        printf '%s=%s\n' "$k" "$v" >> "$ENV_FILE"
    fi
}

validate_username() { [[ "$1" =~ ^[a-zA-Z0-9_]{3,32}$ ]]; }

validate_password() {
    local p="$1"
    [[ ${#p} -ge 12 ]] || return 1
    [[ "$p" =~ [A-Z] ]] || return 1
    [[ "$p" =~ [a-z] ]] || return 1
    [[ "$p" =~ [0-9] ]] || return 1
    [[ "$p" =~ [^A-Za-z0-9] ]] || return 1
    return 0
}

validate_domain() { [[ "$1" =~ ^([a-zA-Z0-9](-?[a-zA-Z0-9])*\.)+[a-zA-Z]{2,}$ ]]; }

apply_server_name() {
    local names="$1"
    sed -i -E "s|^([[:space:]]*server_name).*;|\1 ${names};|g" "$NGINX_SITE"
    nginx -t
    systemctl reload nginx
}

current_domains() {
    local primary fallback
    primary="$(get_env PHONIX_DOMAIN)"
    fallback="$(get_env PHONIX_FALLBACK_DOMAINS)"
    printf '%s %s' "$primary" "$fallback" | xargs -n1 2>/dev/null | awk 'NF' | paste -sd' ' -
}

change_owner() {
    heading "ШӘШәЫҢЫҢШұ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ Щ…Ш§Щ„Ъ©"
    local cur new_user pass pass2
    cur="$(get_env PHONIX_OWNER_USERNAME)"
    say "ЩҶШ§Щ… Ъ©Ш§ШұШЁШұЫҢ ЩҒШ№Щ„ЫҢ: ${cur:-ЩҶШ§Щ…ШҙШ®Шө}"

    read -rp "ЩҶШ§Щ… Ъ©Ш§ШұШЁШұЫҢ Ш¬ШҜЫҢШҜ (Ш®Ш§Щ„ЫҢ = ШЁШҜЩҲЩҶ ШӘШәЫҢЫҢШұ): " new_user
    if [[ -z "$new_user" ]]; then
        new_user="$cur"
    elif ! validate_username "$new_user"; then
        warn "ЩҶШ§Щ… Ъ©Ш§ШұШЁШұЫҢ ЩҶШ§Щ…Ш№ШӘШЁШұ Ш§ШіШӘ."
        return
    fi

    while true; do
        read -rsp "ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЫҢ Ш¬ШҜЫҢШҜ (ШӯШҜШ§ЩӮЩ„ ЫұЫІ Ъ©Ш§ШұШ§Ъ©ШӘШұШҢ ШЁШІШұЪҜ/Ъ©ЩҲЪҶЪ©/Ш№ШҜШҜ/ЩҶЩ…Ш§ШҜ): " pass; echo
        if ! validate_password "$pass"; then warn "ЪҜШ°ШұЩҲШ§ЪҳЩҮ ШҙШұШ§ЫҢШ· ЩҫЫҢЪҶЫҢШҜЪҜЫҢ ШұШ§ ЩҶШҜШ§ШұШҜ."; continue; fi
        read -rsp "ШӘЪ©ШұШ§Шұ ЪҜШ°ШұЩҲШ§ЪҳЩҮ: " pass2; echo
        if [[ "$pass" != "$pass2" ]]; then warn "ЪҜШ°ШұЩҲШ§ЪҳЩҮвҖҢЩҮШ§ ЫҢЪ©ШіШ§ЩҶ ЩҶЫҢШіШӘЩҶШҜ."; continue; fi
        break
    done

    umask 077
    printf 'PHONIX_OWNER_USERNAME=%s\nPHONIX_OWNER_PASSWORD=%s\n' "$new_user" "$pass" > "$OWNER_FILE"
    chmod 600 "$OWNER_FILE"; chown root:root "$OWNER_FILE"
    systemctl restart phoenix-api
    ok "Ш§Ш·Щ„Ш§Ш№Ш§ШӘ Щ…Ш§Щ„Ъ© ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ ШҙШҜ ЩҲ ШіШұЩҲЫҢШі ШұШ§ЩҮвҖҢШ§ЩҶШҜШ§ШІЫҢ Щ…Ш¬ШҜШҜ ШҙШҜ."
}

manage_domain() {
    heading "Щ…ШҜЫҢШұЫҢШӘ ШҜШ§Щ…ЩҶЩҮ"
    local primary fallback domains
    primary="$(get_env PHONIX_DOMAIN)"
    fallback="$(get_env PHONIX_FALLBACK_DOMAINS)"
    say "ШҜШ§Щ…ЩҶЩҮвҖҢЫҢ Ш§ШөЩ„ЫҢ: ${primary:-ЩҶШ§Щ…ШҙШ®Шө}"
    say "ШҜШ§Щ…ЩҶЩҮвҖҢЩҮШ§ЫҢ ЩҫШҙШӘЫҢШЁШ§ЩҶ: ${fallback:-вҖ”}"
    echo
    echo "  1) ШӘШәЫҢЫҢШұ ШҜШ§Щ…ЩҶЩҮвҖҢЫҢ Ш§ШөЩ„ЫҢ"
    echo "  2) Ш§ЩҒШІЩҲШҜЩҶ ШҜШ§Щ…ЩҶЩҮвҖҢЫҢ ЩҫШҙШӘЫҢШЁШ§ЩҶ (Fallback)"
    echo "  0) ШЁШ§ШІЪҜШҙШӘ"
    read -rp "Ш§ЩҶШӘШ®Ш§ШЁ: " sub

    case "$sub" in
        1)
            read -rp "ШҜШ§Щ…ЩҶЩҮвҖҢЫҢ Ш§ШөЩ„ЫҢ Ш¬ШҜЫҢШҜ: " nd
            validate_domain "$nd" || { warn "ШҜШ§Щ…ЩҶЩҮ ЩҶШ§Щ…Ш№ШӘШЁШұ Ш§ШіШӘ."; return; }
            set_env PHONIX_DOMAIN "$nd"
            set_env PHONIX_FRONTEND_URL "https://$nd"
            primary="$nd"
            ;;
        2)
            read -rp "ШҜШ§Щ…ЩҶЩҮвҖҢЫҢ ЩҫШҙШӘЫҢШЁШ§ЩҶ: " nd
            validate_domain "$nd" || { warn "ШҜШ§Щ…ЩҶЩҮ ЩҶШ§Щ…Ш№ШӘШЁШұ Ш§ШіШӘ."; return; }
            if [[ " $fallback " == *" $nd "* ]]; then warn "Ш§ЫҢЩҶ ШҜШ§Щ…ЩҶЩҮ ЩӮШЁЩ„Ш§ЩӢ Ш§Ш¶Ш§ЩҒЩҮ ШҙШҜЩҮ."; return; fi
            fallback="$(printf '%s %s' "$fallback" "$nd" | xargs)"
            set_env PHONIX_FALLBACK_DOMAINS "$fallback"
            ;;
        *) return ;;
    esac

    domains="$(printf '%s %s' "$primary" "$fallback" | xargs)"
    apply_server_name "$domains"

    local args=()
    for d in $domains; do args+=(-d "$d"); done
    certbot --nginx --expand --non-interactive --agree-tos --redirect "${args[@]}"
    systemctl reload nginx
    set_env PHONIX_FRONTEND_URL "https://$primary"
    systemctl restart phoenix-api
    ok "ШҜШ§Щ…ЩҶЩҮвҖҢЩҮШ§ Ш§Ш№Щ…Ш§Щ„ ЩҲ ЪҜЩҲШ§ЩҮЫҢ SSL ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ ШҙШҜ: $domains"
}

prune_releases() {
    local keep="$KEEP_RELEASES"
    ls -1dt "$RELEASES_DIR"/*/ 2>/dev/null | tail -n "+$((keep + 1))" | while read -r old; do
        old="${old%/}"
        [[ "$(readlink -f "$CURRENT_LINK")" == "$old" ]] && continue
        rm -rf "$old"
    done
}

snapshot_data() {
    [[ -f "$DATA_DIR/store.json" ]] || return 0
    mkdir -p "$BACKUP_DIR"
    cp -a "$DATA_DIR/store.json" "$BACKUP_DIR/store-$(date +%Y%m%d%H%M%S).json"
    ls -1dt "$BACKUP_DIR"/store-*.json 2>/dev/null | tail -n "+$((KEEP_DATA_SNAPSHOTS + 1))" | xargs -r rm -f
}

services_healthy() {
    local i
    for i in $(seq 1 30); do
        if curl -fsS -o /dev/null "http://127.0.0.1:$API_PORT/health" \
            && curl -fsS -o /dev/null "http://127.0.0.1:$WEB_PORT"; then
            return 0
        fi
        sleep 1
    done
    return 1
}

restart_stack() {
    systemctl restart phoenix-api
    systemctl restart phoenix-web
    systemctl reload nginx
}

hot_update() {
    heading "ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ ШЁШҜЩҲЩҶ ШӘЩҲЩӮЩҒ"
    local previous; previous="$(readlink -f "$CURRENT_LINK" 2>/dev/null || true)"

    say "ШӘЩҮЫҢЩҮвҖҢЫҢ ЩҶШіШ®ЩҮвҖҢЫҢ ЩҫШҙШӘЫҢШЁШ§ЩҶ Ш§ШІ ШҜШ§ШҜЩҮвҖҢЩҮШ§ (store.json ШҜШұ $DATA_DIR ШҜШіШӘвҖҢЩҶШ®ЩҲШұШҜЩҮ Щ…ЫҢвҖҢЩ…Ш§ЩҶШҜ)..."
    snapshot_data

    say "ШҜШұЫҢШ§ЩҒШӘ ШўШ®ШұЫҢЩҶ ЩҶШіШ®ЩҮ..."
    if [[ -d "$REPO_DIR/.git" ]]; then
        git -C "$REPO_DIR" fetch --all --prune --tags
        git -C "$REPO_DIR" reset --hard origin/main
    else
        git clone "$REPO_URL" "$REPO_DIR"
    fi

    local rel="$RELEASES_DIR/$(date +%Y%m%d%H%M%S)"
    mkdir -p "$rel/api" "$rel/web"

    say "ШіШ§Ш®ШӘ ШЁЪ©вҖҢШ§ЩҶШҜ..."
    dotnet publish "$REPO_DIR/$DOTNET_PROJECT" -c Release -o "$rel/api" --nologo

    say "ШіШ§Ш®ШӘ ЩҒШұШ§ЩҶШӘвҖҢШ§ЩҶШҜ ШҜШұ Щ…ШӯЫҢШ· staging Ш¬ШҜШ§ЪҜШ§ЩҶЩҮ..."
    rsync -a --delete --exclude node_modules --exclude .next "$REPO_DIR/frontend/" "$rel/web/"
    ( cd "$rel/web" && npm ci && NEXT_PUBLIC_API_URL="" NODE_ENV=production npm run build )

    chown -R "$APP_USER:$APP_USER" "$rel"

    say "ШӘШ№ЩҲЫҢШ¶ ЩҶШіШ®ЩҮвҖҢЫҢ ЩҒШ№Ш§Щ„ ЩҲ ШЁШ§ШұЪҜШ°Ш§ШұЫҢ Щ…Ш¬ШҜШҜ ШіШұЩҲЫҢШівҖҢЩҮШ§..."
    ln -sfn "$rel" "$CURRENT_LINK"
    chown -h "$APP_USER:$APP_USER" "$CURRENT_LINK"
    restart_stack

    if services_healthy; then
        prune_releases
        ok "ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Ъ©Ш§Щ…Щ„ ШҙШҜ. ШҜШ§ШҜЩҮвҖҢЩҮШ§ ШӯЩҒШё ШҙШҜЩҶШҜ. ЩҶШіШ®ЩҮвҖҢЫҢ ЩҒШ№Ш§Щ„: $rel"
    else
        warn "ЩҶШіШ®ЩҮвҖҢЫҢ Ш¬ШҜЫҢШҜ ШіШ§Щ„Щ… ШЁШ§Щ„Ш§ ЩҶЫҢШ§Щ…ШҜ вҖ” ШЁШ§ШІЪҜШҙШӘ Ш®ЩҲШҜЪ©Ш§Шұ ШЁЩҮ ЩҶШіШ®ЩҮвҖҢЫҢ ЩӮШЁЩ„ЫҢ..."
        if [[ -n "$previous" && -d "$previous" ]]; then
            ln -sfn "$previous" "$CURRENT_LINK"
            chown -h "$APP_USER:$APP_USER" "$CURRENT_LINK"
            restart_stack
        fi
        rm -rf "$rel"
        warn "ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ ЩҶШ§Щ…ЩҲЩҒЩӮ ШЁЩҲШҜШӣ ШіШұЩҲЫҢШі ШЁЩҮ ЩҶШіШ®ЩҮвҖҢЫҢ ЩҫШ§ЫҢШҜШ§Шұ ЩӮШЁЩ„ЫҢ ШЁШ§ШІЪҜШҙШӘ ЩҲ ШҜШ§ШҜЩҮвҖҢЩҮШ§ ШҜШіШӘвҖҢЩҶШ®ЩҲШұШҜЩҮвҖҢШ§ЩҶШҜ."
    fi
}

banner() {
    clear
    printf "%b\n" "${C_BOLD}${C_CYAN}Phoenix Store вҖ” Щ…ШҜЫҢШұЫҢШӘ ШіЫҢШіШӘЩ…${C_RESET}"
    printf "%b\n" "ШҜШ§Щ…ЩҶЩҮ: ${C_CYAN}$(get_env PHONIX_DOMAIN)${C_RESET}"
    printf "%b\n\n" "ЩҲШ¶Ш№ЫҢШӘ: API=$(systemctl is-active phoenix-api 2>/dev/null) WEB=$(systemctl is-active phoenix-web 2>/dev/null)"
}

menu() {
    while true; do
        banner
        echo "  1) ШӘШәЫҢЫҢШұ/ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ Щ…Ш§Щ„Ъ© (ЩҶШ§Щ… Ъ©Ш§ШұШЁШұЫҢ ЩҲ ЪҜШ°ШұЩҲШ§ЪҳЩҮ)"
        echo "  2) Щ…ШҜЫҢШұЫҢШӘ ШҜШ§Щ…ЩҶЩҮ (ШӘШәЫҢЫҢШұ ШҜШ§Щ…ЩҶЩҮвҖҢЫҢ Ш§ШөЩ„ЫҢ ЫҢШ§ Ш§ЩҒШІЩҲШҜЩҶ ШҜШ§Щ…ЩҶЩҮвҖҢЫҢ ЩҫШҙШӘЫҢШЁШ§ЩҶ)"
        echo "  3) ШЁЩҮвҖҢШұЩҲШІШұШіШ§ЩҶЫҢ ЩҶШұЩ…вҖҢШ§ЩҒШІШ§Шұ ШЁШҜЩҲЩҶ ШӘЩҲЩӮЩҒ ШіШұЩҲЫҢШі"
        echo "  0) Ш®ШұЩҲШ¬"
        echo
        read -rp "ЪҜШІЫҢЩҶЩҮ ШұШ§ Ш§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ: " choice
        case "$choice" in
            1) change_owner ;;
            2) manage_domain ;;
            3) hot_update ;;
            0) exit 0 ;;
            *) warn "ЪҜШІЫҢЩҶЩҮ ЩҶШ§Щ…Ш№ШӘШЁШұ Ш§ШіШӘ." ;;
        esac
        echo
        read -rp "ШЁШұШ§ЫҢ Ш§ШҜШ§Щ…ЩҮ Enter ШЁШІЩҶЫҢШҜ..." _
    done
}

require_root
[[ -f "$ENV_FILE" ]] || die "ЩҫЫҢЪ©ШұШЁЩҶШҜЫҢ ЫҢШ§ЩҒШӘ ЩҶШҙШҜ ($ENV_FILE). Ш§ШЁШӘШҜШ§ install.sh ШұШ§ Ш§Ш¬ШұШ§ Ъ©ЩҶЫҢШҜ."
menu
