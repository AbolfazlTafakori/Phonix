#!/usr/bin/env bash
set -euo pipefail

REPO_URL="https://github.com/AbolfazlTafakori/Phonix.git"
APP_USER="phoenix"
BASE_DIR="/opt/phoenix"
REPO_DIR="$BASE_DIR/repo"
RELEASES_DIR="$BASE_DIR/releases"
CURRENT_LINK="$BASE_DIR/current"
CONF_DIR="/etc/phoenix"
OFFLINE_NUGET_FLAG="/etc/phoenix/nuget-offline"
ENV_FILE="$CONF_DIR/phoenix.env"
SECRET_FILE="$CONF_DIR/secret.env"
OWNER_FILE="$CONF_DIR/owner.env"
NGINX_SITE="/etc/nginx/sites-available/phoenix.conf"
DOTNET_PROJECT="backend/src/Phonix.Api"
DATA_DIR="/var/lib/phoenix"
BACKUP_DIR="$DATA_DIR/backups"
SRC_TARBALL_URL="https://codeload.github.com/AbolfazlTafakori/Phonix/tar.gz/refs/heads/main"
PUI_SRC="$REPO_DIR/deploy/p-ui"
PUI_PATH="/usr/local/bin/p-ui"
API_PORT=5228
WEB_PORT=3000
KEEP_RELEASES=3
KEEP_DATA_SNAPSHOTS=10

C_RESET="\033[0m"; C_BOLD="\033[1m"; C_BLUE="\033[1;34m"; C_GREEN="\033[1;32m"
C_YELLOW="\033[1;33m"; C_RED="\033[1;31m"; C_CYAN="\033[1;36m"

say()  { printf "%b\n" "${C_BLUE}::${C_RESET} $*"; }
ok()   { printf "%b\n" "${C_GREEN}✔${C_RESET} $*"; }
warn() { printf "%b\n" "${C_YELLOW}!${C_RESET} $*"; }
die()  { printf "%b\n" "${C_RED}✖${C_RESET} $*" >&2; exit 1; }
heading() { printf "\n%b\n" "${C_BOLD}${C_CYAN}== $* ==${C_RESET}"; }

require_root() {
    [[ $EUID -eq 0 ]] || die "This tool must run as root (use: sudo p-ui)."
}

get_env() { grep -E "^$1=" "$ENV_FILE" 2>/dev/null | head -n1 | cut -d= -f2- || true; }

set_env() {
    local k="$1" v="$2"
    if grep -qE "^$k=" "$ENV_FILE"; then
        sed -i "s|^$k=.*|$k=$v|" "$ENV_FILE"
    else
        printf '%s=%s\n' "$k" "$v" >> "$ENV_FILE"
    fi
}

validate_username() { [[ "$1" =~ ^[a-zA-Z0-9_]{3,32}$ ]]; }

validate_password() {
    local p="$1"
    [[ ${#p} -ge 12 ]] || return 1
    [[ "$p" =~ [A-Z] ]] || return 1
    [[ "$p" =~ [a-z] ]] || return 1
    [[ "$p" =~ [0-9] ]] || return 1
    [[ "$p" =~ [^A-Za-z0-9] ]] || return 1
    return 0
}

validate_domain() { [[ "$1" =~ ^([a-zA-Z0-9](-?[a-zA-Z0-9])*\.)+[a-zA-Z]{2,}$ ]]; }
validate_https_url() { [[ "$1" =~ ^https://.+ ]]; }
validate_cluster_secret() { [[ -n "$1" && ${#1} -ge 16 ]]; }

set_secret() {
    local k="$1" v="$2"
    umask 077
    if [[ -f "$SECRET_FILE" ]] && grep -qE "^$k=" "$SECRET_FILE"; then
        sed -i "s|^$k=.*|$k=$v|" "$SECRET_FILE"
    else
        printf '%s=%s\n' "$k" "$v" >> "$SECRET_FILE"
    fi
    chmod 600 "$SECRET_FILE"; chown root:root "$SECRET_FILE"
}

apply_server_name() {
    local names="$1"
    sed -i -E "s|^([[:space:]]*server_name).*;|\1 ${names};|g" "$NGINX_SITE"
    nginx -t
    systemctl reload nginx
}

change_owner() {
    heading "Update owner credentials"
    local cur new_user pass pass2
    cur="$(get_env PHONIX_OWNER_USERNAME)"
    say "Current username: ${cur:-unknown}"

    read -rp "New username (leave empty to keep current): " new_user
    if [[ -z "$new_user" ]]; then
        new_user="$cur"
    elif ! validate_username "$new_user"; then
        warn "Invalid username."
        return
    fi

    while true; do
        read -rsp "New password (min 12 chars: upper, lower, number, symbol): " pass; echo
        if ! validate_password "$pass"; then warn "Password does not meet the complexity requirements."; continue; fi
        read -rsp "Confirm password: " pass2; echo
        if [[ "$pass" != "$pass2" ]]; then warn "Passwords do not match."; continue; fi
        break
    done

    umask 077
    printf 'PHONIX_OWNER_USERNAME=%s\nPHONIX_OWNER_PASSWORD=%s\n' "$new_user" "$pass" > "$OWNER_FILE"
    chmod 600 "$OWNER_FILE"; chown root:root "$OWNER_FILE"
    systemctl restart phoenix-api
    ok "Owner credentials updated and service restarted."
}

manage_domain() {
    heading "Domain management"
    local primary fallback domains
    primary="$(get_env PHONIX_DOMAIN)"
    fallback="$(get_env PHONIX_FALLBACK_DOMAINS)"
    say "Primary domain:   ${primary:-unknown}"
    say "Fallback domains: ${fallback:-none}"
    echo
    echo "  1) Change the primary domain"
    echo "  2) Add a fallback domain"
    echo "  0) Back"
    read -rp "Select: " sub

    case "$sub" in
        1)
            read -rp "New primary domain: " nd
            validate_domain "$nd" || { warn "Invalid domain."; return; }
            set_env PHONIX_DOMAIN "$nd"
            set_env PHONIX_FRONTEND_URL "https://$nd"
            primary="$nd"
            ;;
        2)
            read -rp "Fallback domain: " nd
            validate_domain "$nd" || { warn "Invalid domain."; return; }
            if [[ " $fallback " == *" $nd "* ]]; then warn "That domain is already configured."; return; fi
            fallback="$(printf '%s %s' "$fallback" "$nd" | xargs)"
            set_env PHONIX_FALLBACK_DOMAINS "$fallback"
            ;;
        *) return ;;
    esac

    domains="$(printf '%s %s' "$primary" "$fallback" | xargs)"
    apply_server_name "$domains"

    local args=()
    for d in $domains; do args+=(-d "$d"); done
    certbot --nginx --expand --non-interactive --agree-tos --redirect "${args[@]}"
    systemctl reload nginx
    set_env PHONIX_FRONTEND_URL "https://$primary"
    systemctl restart phoenix-api
    ok "Domains applied and SSL certificate updated: $domains"
}

cluster_setup() {
    heading "High-availability cluster setup"
    local current_mode; current_mode="$(get_env PHONIX_CLUSTER_MODE)"
    say "Current mode: ${current_mode:-standalone (not clustered)}"
    [[ -n "$current_mode" && "$current_mode" != "standalone" ]] && say "Node id: $(get_env PHONIX_NODE_ID) — Peer: $(get_env PHONIX_CLUSTER_PEER)"
    echo
    echo "  1) Primary — the main, always-writable server"
    echo "  2) Standby — the backup server that mirrors the Primary"
    echo "  0) Back"
    read -rp "Select this server's role: " role_choice

    case "$role_choice" in
        1) cluster_setup_primary ;;
        2) cluster_setup_standby ;;
        *) return ;;
    esac
}

cluster_setup_primary() {
    heading "Configure THIS server as Primary"
    local node_id peer secret existing_secret

    read -rp "A short label for this server (e.g. germany): " node_id
    [[ -n "$node_id" ]] || { warn "A label is required."; return; }

    while true; do
        read -rp "Standby server's reachable address (must start with https://, e.g. https://iran-server:5228): " peer
        validate_https_url "$peer" && break
        warn "The peer address must start with https:// — plain http is rejected by the app."
    done

    existing_secret="$(grep -E '^PHONIX_CLUSTER_SECRET=' "$SECRET_FILE" 2>/dev/null | cut -d= -f2- || true)"
    if [[ -n "$existing_secret" ]]; then
        secret="$existing_secret"
        warn "A cluster secret already exists on this server and will be reused — copy it to the Standby."
    else
        secret="$(openssl rand -base64 32)"
        set_secret PHONIX_CLUSTER_SECRET "$secret"
        ok "Generated a new cluster secret."
    fi

    set_env PHONIX_CLUSTER_MODE primary
    set_env PHONIX_NODE_ID "$node_id"
    set_env PHONIX_CLUSTER_PEER "$peer"

    systemctl restart phoenix-api
    services_healthy || warn "The service did not come up healthy after the restart — check: journalctl -u phoenix-api -n 50"

    printf "\n%b\n" "${C_RED}${C_BOLD}┌────────────────────────────────────────────────────────────────┐${C_RESET}"
    printf "%b\n"   "${C_RED}${C_BOLD}│  PHONIX_CLUSTER_SECRET — copy this to the Standby setup now      │${C_RESET}"
    printf "%b\n"   "${C_RED}${C_BOLD}└────────────────────────────────────────────────────────────────┘${C_RESET}"
    printf "\n    %b\n\n" "${C_BOLD}${secret}${C_RESET}"
    ok "This server is Primary. On the other server, run p-ui → cluster setup → Standby, using this secret and this server's https address as the peer."
}

cluster_setup_standby() {
    heading "Configure THIS server as Standby"
    local node_id peer secret

    read -rp "A short label for this server (e.g. iran): " node_id
    [[ -n "$node_id" ]] || { warn "A label is required."; return; }

    while true; do
        read -rp "Primary server's reachable address (must start with https://, e.g. https://germany-server:5228): " peer
        validate_https_url "$peer" && break
        warn "The peer address must start with https:// — plain http is rejected by the app."
    done

    while true; do
        read -rsp "Cluster secret (paste the value shown on the Primary): " secret; echo
        validate_cluster_secret "$secret" && break
        warn "That doesn't look like a valid secret (too short)."
    done

    set_secret PHONIX_CLUSTER_SECRET "$secret"
    set_env PHONIX_CLUSTER_MODE standby
    set_env PHONIX_NODE_ID "$node_id"
    set_env PHONIX_CLUSTER_PEER "$peer"

    systemctl restart phoenix-api
    services_healthy || warn "The service did not come up healthy after the restart — check: journalctl -u phoenix-api -n 50"

    ok "This server is Standby and will bootstrap and sync from the Primary automatically."
    say "Track progress in the admin panel → Cluster Management (pending events should reach 0)."
}

prune_releases() {
    ls -1dt "$RELEASES_DIR"/*/ 2>/dev/null | tail -n "+$((KEEP_RELEASES + 1))" | while read -r old; do
        old="${old%/}"
        [[ "$(readlink -f "$CURRENT_LINK")" == "$old" ]] && continue
        rm -rf "$old"
    done
}

snapshot_data() {
    [[ -f "$DATA_DIR/store.json" ]] || return 0
    mkdir -p "$BACKUP_DIR"
    cp -a "$DATA_DIR/store.json" "$BACKUP_DIR/store-$(date +%Y%m%d%H%M%S).json"
    ls -1dt "$BACKUP_DIR"/store-*.json 2>/dev/null | tail -n "+$((KEEP_DATA_SNAPSHOTS + 1))" | xargs -r rm -f
}

services_healthy() {
    local i
    for i in $(seq 1 30); do
        # Errors are silenced: this polls during a restart, so the first few attempts are expected to
        # fail and printing them makes a normal restart look like a failure.
        if curl -fsS -o /dev/null "http://127.0.0.1:$API_PORT/health" 2>/dev/null \
            && curl -fsS -o /dev/null "http://127.0.0.1:$WEB_PORT" 2>/dev/null; then
            return 0
        fi
        sleep 1
    done
    return 1
}

# Pulls the source as a plain HTTPS archive instead of over the git protocol. Some networks let ordinary
# HTTPS through but kill git's long-lived transfer, which leaves a node unable to update at all. The
# download is retried and only swapped in after the extracted tree is confirmed to look like the repo,
# so a truncated or rejected transfer leaves the working source untouched.
fetch_source_archive() {
    local tmp dir
    tmp="$(mktemp -d)"
    if ! curl -fL --retry 5 --retry-delay 3 --retry-all-errors --connect-timeout 20 \
        -o "$tmp/src.tar.gz" "$SRC_TARBALL_URL"; then
        rm -rf "$tmp"; return 1
    fi
    if ! tar xzf "$tmp/src.tar.gz" -C "$tmp"; then
        rm -rf "$tmp"; return 1
    fi
    dir="$(find "$tmp" -mindepth 1 -maxdepth 1 -type d | head -n1)"
    if [[ ! -d "$dir/backend" || ! -d "$dir/frontend" ]]; then
        warn "The downloaded archive did not contain the expected source tree."
        rm -rf "$tmp"; return 1
    fi
    mkdir -p "$REPO_DIR"
    rsync -a --delete --exclude .git "$dir/" "$REPO_DIR/"
    rm -rf "$tmp"
    return 0
}

# Points NuGet at no remote source so restore resolves purely from the local package cache. Written into
# the source tree, which a source refresh wipes — hence the flag in $CONF_DIR that remembers the decision.
write_offline_nuget_config() {
    cat > "$REPO_DIR/nuget.config" <<'XML'
<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
  </packageSources>
</configuration>
XML
}

# Publishes the backend, falling back to an offline restore when nuget.org can't be reached.
#
# Reachability is decided by attempting the build, not by probing the host first: a probe can complete a
# TCP handshake and look healthy on a network that then stalls the actual package requests until they time
# out, which is exactly how this fails in practice. Once a host has proven it needs the offline path, the
# flag file skips the slow first attempt on every later build.
publish_backend() {
    local out="$1"

    if [[ -f "$OFFLINE_NUGET_FLAG" ]]; then
        say "Using the local NuGet cache (nuget.org was unreachable on an earlier build)."
        write_offline_nuget_config
        dotnet publish "$REPO_DIR/$DOTNET_PROJECT" -c Release -o "$out" --nologo
        return
    fi

    rm -f "$REPO_DIR/nuget.config"
    if dotnet publish "$REPO_DIR/$DOTNET_PROJECT" -c Release -o "$out" --nologo; then
        return 0
    fi

    [[ -d "$HOME/.nuget/packages" ]] || {
        warn "The backend build failed and there is no local NuGet cache to fall back to."
        return 1
    }

    warn "The backend build could not reach nuget.org — retrying against the local package cache."
    write_offline_nuget_config
    if dotnet publish "$REPO_DIR/$DOTNET_PROJECT" -c Release -o "$out" --nologo; then
        touch "$OFFLINE_NUGET_FLAG"
        ok "Built from the local cache; later builds will use it directly."
        return 0
    fi
    return 1
}

# Refreshes this very tool from the release that was just pulled, so a new menu option ships with a
# normal update instead of needing a manual copy. Writing to a temp file and renaming keeps the
# currently-running process on the old inode — bash reads a script incrementally, so overwriting it
# in place mid-run would corrupt execution.
self_update() {
    [[ -f "$PUI_SRC" ]] || return 0
    cmp -s "$PUI_SRC" "$PUI_PATH" && return 0
    local tmp; tmp="$(mktemp "${PUI_PATH}.new.XXXXXX")"
    cat "$PUI_SRC" > "$tmp"
    chmod 0755 "$tmp"; chown root:root "$tmp"
    mv -f "$tmp" "$PUI_PATH"
    ok "The p-ui tool was updated — the new menu takes effect the next time you run it."
}

restart_stack() {
    systemctl restart phoenix-api
    systemctl restart phoenix-web
    systemctl reload nginx
}

hot_update() {
    heading "Zero-downtime update"
    local previous; previous="$(readlink -f "$CURRENT_LINK" 2>/dev/null || true)"

    say "Snapshotting data (store.json in $DATA_DIR is never overwritten)..."
    snapshot_data

    say "Fetching the latest release..."
    # Prefer git when the checkout has it and the remote answers; otherwise fall back to the HTTPS
    # archive, which is what keeps nodes on restricted networks updatable. Only if both fail do we
    # rebuild whatever source is already on disk.
    if [[ -d "$REPO_DIR/.git" ]] \
        && git -C "$REPO_DIR" fetch --all --prune --tags \
        && git -C "$REPO_DIR" reset --hard origin/main; then
        ok "Updated to the latest origin/main."
    elif fetch_source_archive; then
        ok "Updated from the source archive over HTTPS."
    elif [[ -d "$REPO_DIR/backend" && -d "$REPO_DIR/frontend" ]]; then
        warn "Could not reach GitHub — rebuilding from the source already in $REPO_DIR."
    else
        die "Could not reach GitHub and there is no source in $REPO_DIR to build from."
    fi

    local rel="$RELEASES_DIR/$(date +%Y%m%d%H%M%S)"
    mkdir -p "$rel/api" "$rel/web"

    say "Building backend..."
    publish_backend "$rel/api"

    say "Building frontend in a separate staging directory..."
    rsync -a --delete --exclude node_modules --exclude .next "$REPO_DIR/frontend/" "$rel/web/"
    ( cd "$rel/web" && npm ci && NEXT_PUBLIC_API_URL="" NODE_ENV=production npm run build )

    chown -R "$APP_USER:$APP_USER" "$rel"

    say "Switching the active release and reloading services..."
    ln -sfn "$rel" "$CURRENT_LINK"
    chown -h "$APP_USER:$APP_USER" "$CURRENT_LINK"
    restart_stack

    if services_healthy; then
        prune_releases
        self_update
        ok "Update complete. Data preserved. Active release: $rel"
    else
        warn "The new release did not come up healthy — rolling back automatically..."
        if [[ -n "$previous" && -d "$previous" ]]; then
            ln -sfn "$previous" "$CURRENT_LINK"
            chown -h "$APP_USER:$APP_USER" "$CURRENT_LINK"
            restart_stack
        fi
        rm -rf "$rel"
        warn "Update failed; the service was rolled back to the previous release and your data is intact."
    fi
}

banner() {
    clear
    printf "%b\n" "${C_BOLD}${C_CYAN}Phoenix Store — System Management${C_RESET}"
    printf "%b\n" "Domain: ${C_CYAN}$(get_env PHONIX_DOMAIN)${C_RESET}"
    printf "%b\n\n" "Status: API=$(systemctl is-active phoenix-api 2>/dev/null) WEB=$(systemctl is-active phoenix-web 2>/dev/null)"
}

menu() {
    while true; do
        banner
        echo "  1) Update owner credentials (username and password)"
        echo "  2) Domain management (change primary or add a fallback)"
        echo "  3) Zero-downtime application update"
        echo "  4) High-availability cluster setup (Primary / Standby)"
        echo "  0) Exit"
        echo
        read -rp "Choose an option: " choice
        case "$choice" in
            1) change_owner ;;
            2) manage_domain ;;
            3) hot_update ;;
            4) cluster_setup ;;
            0) exit 0 ;;
            *) warn "Invalid option." ;;
        esac
        echo
        read -rp "Press Enter to continue..." _
    done
}

require_root
[[ -f "$ENV_FILE" ]] || die "Configuration not found ($ENV_FILE). Run install.sh first."
menu
